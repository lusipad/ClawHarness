OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_DATA_DIR=./.data/openclaw
OPENCLAW_WORKSPACE_DIR=./.data/workspace/harness
HARNESS_DATA_DIR=./.data/harness
OPENCLAW_FORCE_RENDER_CONFIG=0
OPENCLAW_GATEWAY_BASE_URL=http://openclaw-gateway:18789
OPENCLAW_AGENT_CWD=/home/node/.openclaw/workspace/harness
OPENCLAW_GATEWAY_PUBLISH_ADDR=127.0.0.1
HARNESS_BRIDGE_PUBLISH_ADDR=127.0.0.1
OPENCLAW_BOT_VIEW_PUBLISH_ADDR=127.0.0.1
HARNESS_BASE_URL=http://harness-bridge:8080
OPENCLAW_BOT_REVIEW_REF=81deb042b5caecf109db9f7fa031b5063b671e20
# bot-view sidecar 访问 bridge 只读 API 的 token；如配置了 HARNESS_READONLY_TOKEN，建议填同一值。
HARNESS_API_TOKEN=

# 必填：业务侧接入配置
# 默认示例仍使用 Azure DevOps。若要切到 GitHub，请同步修改 deploy/config/providers.yaml。
ADO_BASE_URL=
ADO_PROJECT=
ADO_PAT=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOKS_TOKEN=
HARNESS_INGRESS_TOKEN=
HARNESS_READONLY_TOKEN=

# 必填：Codex 上游配置
# 留空表示走默认 OpenAI 官方地址；如果你使用 Codex 转发 endpoint，在这里填完整 base URL。
OPENAI_BASE_URL=
# 必须是与你的 OPENAI_BASE_URL 配套可用的 API key；不是 gateway token。
OPENAI_API_KEY=
CODEX_MODEL=gpt-5.4

# 可选：稳定的 Codex 调优项
CODEX_REVIEW_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=xhigh
HARNESS_IMAGE_MODEL=

# 可选：扩展接入项
ADO_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
RC_WEBHOOK_URL=
RC_COMMAND_TOKEN=

# 高级覆盖模式：只有在你明确要接管内部 Codex 配置时才设置
# CODEX_HOME_DIR=./.data/codex
# CODEX_CLI_VERSION=0.118.0
