OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_DATA_DIR=./.data/openclaw
OPENCLAW_WORKSPACE_DIR=./.data/workspace/harness
HARNESS_DATA_DIR=./.data/harness
LOCAL_REPO_DIR=./.data/local/repo
LOCAL_TASKS_DIR=./.data/local/tasks
LOCAL_REVIEW_DIR=./.data/local/reviews
OPENCLAW_FORCE_RENDER_CONFIG=0
OPENCLAW_GATEWAY_BASE_URL=http://openclaw-gateway:18789
OPENCLAW_AGENT_CWD=/home/node/.openclaw/workspace/harness
OPENCLAW_GATEWAY_PUBLISH_ADDR=127.0.0.1
HARNESS_BRIDGE_PUBLISH_ADDR=127.0.0.1
OPENCLAW_BOT_VIEW_PUBLISH_ADDR=127.0.0.1
HARNESS_BASE_URL=http://harness-bridge:8080
OPENCLAW_BOT_REVIEW_REF=81deb042b5caecf109db9f7fa031b5063b671e20
HARNESS_PROVIDER_PROFILE=local-task
HARNESS_SHELL_ENABLED=0
HARNESS_EXECUTOR_BACKEND=codex-cli
# bot-view sidecar 访问 bridge 运行态 API 的 token；优先填 HARNESS_API_TOKEN。
# 若只配置 HARNESS_CONTROL_TOKEN，sidecar 的只读代理也会回退使用它。
HARNESS_API_TOKEN=

# core-only 默认只需要本地路径；切到 Azure 或 GitHub 时，把 HARNESS_PROVIDER_PROFILE 改成对应值。
LOCAL_REPO_PATH=/mnt/local-repo
LOCAL_TASKS_PATH=/mnt/local-tasks
LOCAL_REVIEW_PATH=/mnt/local-reviews
LOCAL_BASE_BRANCH=
LOCAL_PUSH_ENABLED=0

# 仅在启用 shell profile 时需要
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOKS_TOKEN=

# 仅在接收 webhook 或启用受控 API 时需要
HARNESS_INGRESS_TOKEN=
HARNESS_READONLY_TOKEN=
HARNESS_CONTROL_TOKEN=

# 仅在 Azure DevOps profile 下需要
ADO_BASE_URL=
ADO_PROJECT=
ADO_PAT=
ADO_WEBHOOK_SECRET=

# 必填：Codex 上游配置
# 留空表示走默认 OpenAI 官方地址；如果你使用 Codex 转发 endpoint，在这里填完整 base URL。
OPENAI_BASE_URL=
# 必须是与你的 OPENAI_BASE_URL 配套可用的 API key；不是 gateway token。
OPENAI_API_KEY=
CODEX_MODEL=gpt-5.4

# 可选：稳定的 Codex 调优项
CODEX_REVIEW_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=xhigh
HARNESS_IMAGE_MODEL=

# 可选：扩展接入项
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
RC_WEBHOOK_URL=
RC_COMMAND_TOKEN=

# 高级覆盖模式：只有在你明确要接管内部 Codex 配置时才设置
# CODEX_HOME_DIR=./.data/codex
# CODEX_CLI_VERSION=0.118.0
